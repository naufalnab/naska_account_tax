<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_tree_inherit_faktur_pajak" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.faktur.pajak</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_partner_display_name'][last()]" position="after">
                <field name="x_no_faktur_pajak" optional="show" string="No Faktur Pajak"/>
            </xpath>
        </field>
    </record>
</odoo>
